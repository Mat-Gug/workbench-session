\n    background-color: #fafbfe;\n    color: #112277;\n    font-family: 'Avenir Next for SAS', Arial, 'Albany AMT', Helvetica, Helv;\n    font-size: 14px;\n    font-style: normal;\n    font-weight: bold;\n}\n.usertext {\n    background-color: #fafbfe;\n    color: #112277;\n    font-family: 'Avenir Next for SAS', Arial, 'Albany AMT', Helvetica, Helv;\n    font-size: 14px;\n    font-style: normal;\n    font-weight: normal;\n}\na:visited { color: #800080 }\n.warnbanner {\n    background-color: #fafbfe;\n    color: #112277;\n    font-family: 'Avenir Next for SAS', Arial, 'Albany AMT', Helvetica, Helv;\n    font-size: 14px;\n    font-style: normal;\n    font-weight: bold;\n}\n.warncontent {\n    background-color: #fafbfe;\n    color: #112277;\n    font-family: 'Avenir Next for SAS', Arial, 'Albany AMT', Helvetica, Helv;\n    font-size: 14px;\n    font-style: normal;\n    font-weight: normal;\n}\n.warncontentfixed {\n    background-color: #fafbfe;\n    color: #112277;\n    font-family: 'Courier New', Courier;\n    font-size: 14px;\n    font-style: normal;\n    font-weight: normal;\n}\n/*]]>*/\n</style>\n</head>\n<body class=\"c body\">\n<div style=\"padding-bottom: 8px; padding-top: 1px\">\n<div id=\"IDX\" class=\"proc_title_group\">\n<p class=\"c proctitle\">The TREESPLIT Procedure</p>\n</div>\n<div style=\"padding-bottom: 8px; padding-top: 1px\">\n<table class=\"table\" style=\"border-spacing: 0\" aria-label=\"Model Information\">\n<caption aria-label=\"Model Information\"></caption>\n<colgroup><col/><col/></colgroup><colgroup></colgroup>\n<thead>\n<tr>\n<th class=\"c b header\" colspan=\"2\" scope=\"colgroup\">Model Information</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<th class=\"rowheader\" scope=\"row\">Split Criterion</th>\n<th class=\"r data\">IGR</th>\n</tr>\n<tr>\n<th class=\"rowheader\" scope=\"row\">Pruning Method</th>\n<th class=\"r data\">None</th>\n</tr>\n<tr>\n<th class=\"rowheader\" scope=\"row\">Max Branches per Node</th>\n<th class=\"r data\">2</th>\n</tr>\n<tr>\n<th class=\"rowheader\" scope=\"row\">Max Tree Depth</th>\n<th class=\"r data\">10</th>\n</tr>\n<tr>\n<th class=\"rowheader\" scope=\"row\">Tree Depth Before Pruning</th>\n<th class=\"r data\">10</th>\n</tr>\n<tr>\n<th class=\"rowheader\" scope=\"row\">Tree Depth After Pruning</th>\n<th class=\"r data\">10</th>\n</tr>\n<tr>\n<th class=\"rowheader\" scope=\"row\">Number of Leaves Before Pruning</th>\n<th class=\"r data\">70</th>\n</tr>\n<tr>\n<th class=\"rowheader\" scope=\"row\">Number of Leaves After Pruning</th>\n<th class=\"r data\">70</th>\n</tr>\n</tbody>\n</table>\n</div>\n<div id=\"IDX1\" style=\"padding-bottom: 8px; padding-top: 1px\">\n<table class=\"table\" style=\"border-spacing: 0\" aria-label=\"Observation Information\">\n<caption aria-label=\"Observation Information\"></caption>\n<colgroup><col/><col/></colgroup>\n<thead>\n<tr>\n<th class=\"c headerempty\" scope=\"col\">&#160;</th>\n<th class=\"r b header\" scope=\"col\">Training</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<th class=\"rowheader\" scope=\"row\">Number of Observations Read</th>\n<td class=\"r data\">5960</td>\n</tr>\n<tr>\n<th class=\"rowheader\" scope=\"row\">Number of Observations Used</th>\n<td class=\"r data\">5960</td>\n</tr>\n</tbody>\n</table>\n</div>\n<hr class=\"pagebreak\"/>\n<div id=\"IDX2\" class=\"proc_title_group\">\n<p class=\"c proctitle\">The TREESPLIT Procedure</p>\n</div>\n<div style=\"padding-bottom: 8px; padding-top: 1px\">\n<div style=\"padding-bottom: 8px; padding-top: 1px\">\n<div class=\"c\">\n<script type=\"text/ecmascript\">\r\nvar SVG_IDX2_SVGRoot = null;\r\nvar SVG_IDX2_TrueCoords = null;\r\nvar SVG_IDX2_singleTip = null;\r\nvar SVG_IDX2_singleBox = null;\r\nvar SVG_IDX2_singleText = null;\r\nvar SVG_IDX2_tiptspan = null;\r\nvar SVG_IDX2_attrScale = 1;\r\nvar SVG_IDX2_rightEdge = null;\r\nvar SVG_IDX2_SVGHeight = null;\r\nvar SVG_IDX2_SVGWidth = null;\r\nfunction SVG_IDX2_Init(anchor) {\r\n   SVG_IDX2_SVGRoot = document.getElementById(anchor);\r\n   SVG_IDX2_TrueCoords = SVG_IDX2_SVGRoot.createSVGPoint();\r\n   SVG_IDX2_singleTip = document.getElementById(anchor + '_singleTip1');\r\n   SVG_IDX2_singleBox = document.getElementById(anchor + '_singleBox1');\r\n   SVG_IDX2_singleText = document.getElementById(anchor + '_singleText1');\r\n   SVG_IDX2_tiptspan = document.getElementById(anchor + '_tiptspan1');\r\n   SVG_IDX2_tiptspan.firstChild.nodeValue = null;\r\n   SVG_IDX2_SVGRoot.addEventListener('mousemove', SVG_IDX2_ShowTooltip, false);\r\n   SVG_IDX2_SVGRoot.addEventListener('mouseout', SVG_IDX2_HideTooltip, false);\r\n   SVG_IDX2_SVGHeight = SVG_IDX2_SVGRoot.getAttributeNS(null, \"height\");\r\n   SVG_IDX2_SVGWidth = SVG_IDX2_SVGRoot.getAttributeNS(null, \"width\");\r\n   if (!isNaN(parseFloat(SVG_IDX2_SVGHeight)) && !isNaN(parseFloat(SVG_IDX2_SVGWidth)))\r\n      SVG_IDX2_GetHW();\r\n}\r\nfunction SVG_IDX2_GetHW()\r\n{\r\n    if (SVG_IDX2_SVGWidth != null && SVG_IDX2_SVGWidth != \"\") {\r\n       if (SVG_IDX2_SVGWidth.match(/%/)) {\r\n          var factor = parseFloat(SVG_IDX2_SVGWidth.replace(/%/,\"\"))/100;\r\n          SVG_IDX2_SVGWidth = window.innerWidth * factor;\r\n       }\r\n       else if (SVG_IDX2_SVGWidth.match(/in/))\r\n          SVG_IDX2_SVGWidth = parseFloat(SVG_IDX2_SVGWidth.replace(/in/,\"\"))*96;\r\n       else if (SVG_IDX2_SVGWidth.match(/cm/))\r\n          SVG_IDX2_SVGWidth = parseFloat(SVG_IDX2_SVGWidth.replace(/in/,\"\"))*96/2.54;\r\n       else\r\n           SVG_IDX2_SVGWidth = parseFloat(SVG_IDX2_SVGWidth);\r\n    }\r\n    if (SVG_IDX2_SVGHeight != null && SVG_IDX2_SVGHeight != \"\") {\r\n       if (SVG_IDX2_SVGHeight.match(/%/)) {\r\n          var factor = parseFloat(SVG_IDX2_SVGHeight.replace(/%/,\"\"))/100;\r\n          SVG_IDX2_SVGHeight = window.innerHeight * factor;\r\n       }\r\n       else if (SVG_IDX2_SVGHeight.match(/in/))\r\n          SVG_IDX2_SVGHeight = parseFloat(SVG_IDX2_SVGHeight.replace(/in/,\"\"))*96;\r\n       else if (SVG_IDX2_SVGHeight.match(/cm/))\r\n          SVG_IDX2_SVGHeight = parseFloat(SVG_IDX2_SVGHeight.replace(/in/,\"\"))*96/2.54;\r\n       else\r\n           SVG_IDX2_SVGHeight = parseFloat(SVG_IDX2_SVGHeight);\r\n    }\r\n}\r\nfunction SVG_IDX2_GetScaleFactors(evt)\r\n{\r\n   var zoomFactor = 1;\r\n   windowWidth  = (top.innerWidth==undefined)  ? window.innerWidth  : top.innerWidth;\r\n   windowHeight = (top.innerHeight==undefined) ? window.innerHeight : top.innerHeight;\r\n   SVG_IDX2_rightEdge = (SVG_IDX2_SVGWidth) ? SVG_IDX2_SVGWidth - window.pageXOffset : windowWidth;\r\n   if (parseFloat(SVG_IDX2_SVGWidth) > 0 || parseFloat(SVG_IDX2_SVGHeight) > 0)\r\n      var tipScale = 1.4423;\r\n   else {\r\n      var tipXScale  = (screen.width/windowWidth) / SVG_IDX2_SVGRoot.currentScale;\r\n      var tipYScale  = (screen.height/windowHeight) / SVG_IDX2_SVGRoot.currentScale;\r\n      var tipScale   = (tipXScale + tipYScale)/2.0;\r\n   }\r\n   SVG_IDX2_attrScale = tipScale;\r\n   if (navigator.appName == 'Adobe SVG Viewer') {\r\n      if (screen.deviceXDPI != null && screen.logicalXDPI != null)\r\n         zoomFactor = screen.deviceXDPI/screen.logicalXDPI;\r\n      SVG_IDX2_attrScale = zoomFactor*tipScale;\r\n   }\r\n   else if (navigator.userAgent != null && navigator.userAgent != '') {\r\n      var ua = navigator.userAgent.toLowerCase();\r\n      if (ua.indexOf(\"msie\") != -1 || ua.indexOf(\"trident\") != -1) {\r\n         zoomFactor = screen.deviceXDPI/screen.logicalXDPI;\r\n         SVG_IDX2_attrScale = tipScale/zoomFactor;\r\n         SVG_IDX2_rightEdge /= zoomFactor;\r\n      }\r\n      else if (ua.indexOf(\"ipad\") != -1) {\r\n         zoomFactor = SVG_IDX2_SVGRoot.clientWidth / window.innerWidth;\r\n         SVG_IDX2_attrScale = 1.5 / zoomFactor;\r\n         SVG_IDX2_rightEdge /= zoomFactor;\r\n      }\r\n      else if (ua.indexOf(\"opera\") != -1)\r\n         SVG_IDX2_attrScale = tipScale;\r\n      else if (ua.indexOf(\"firefox\") != -1)\r\n         SVG_IDX2_attrScale = tipScale;\r\n      else {\r\n         if (SVG_IDX2_SVGWidth > 0 || SVG_IDX2_SVGHeight > 0)\r\n            zoomFactor = 1;\r\n         else\r\n            zoomFactor = parseInt(document.defaultView.getComputedStyle(SVG_IDX2_SVGRoot, null).width,10)/\r\n                                  SVG_IDX2_SVGRoot.clientWidth;\r\n         SVG_IDX2_attrScale = tipScale/zoomFactor;\r\n         SVG_IDX2_rightEdge *= zoomFactor;\r\n      }\r\n   }\r\n}\r\nfunction SVG_IDX2_GetTrueCoords(evt)\r\n{\r\n   var trans = SVG_IDX2_SVGRoot.currentTranslate;\r\n   var scale = SVG_IDX2_SVGRoot.currentScale;\r\n   SVG_IDX2_GetScaleFactors();\r\n   var p1    = SVG_IDX2_SVGRoot.createSVGPoint();\r\n   var p2;\r\n      var m = SVG_IDX2_SVGRoot.getScreenCTM();\r\n      if (navigator.userAgent.toLowerCase().indexOf(\"ipad\") != -1) {\r\n         p1.x = evt.clientX + window.pageXOffset;\r\n         p1.y = evt.clientY + window.pageYOffset;\r\n      }\r\n      else {\r\n      p1.x = evt.clientX;\r\n      p1.y = evt.clientY;\r\n      }\r\n      p2 = p1.matrixTransform(m.inverse());\r\n   SVG_IDX2_TrueCoords.x = Math.round(p2.x*100) / 100;\r\n   SVG_IDX2_TrueCoords.y = Math.round(p2.y*100) / 100;\r\n}\r\nfunction SVG_IDX2_HideTooltip( evt )\r\n{\r\n   SVG_IDX2_tiptspan.firstChild.nodeValue = null;\r\n   SVG_IDX2_singleTip.setAttributeNS(null, 'visibility', 'hidden');\r\n}\r\nfunction SVG_IDX2_ShowTooltip( evt )\r\n{\r\n   SVG_IDX2_GetTrueCoords( evt );\r\n   var targetElement = evt.target;\r\n   var tspanCount = targetElement.getElementsByTagName('desc').length;\r\n   if (tspanCount == 1) {\r\n      var targetTspan = targetElement.getElementsByTagName('desc').item(0);\r\n      if ( targetTspan) {\r\n         if (targetTspan.firstChild != null)\r\n            SVG_IDX2_tiptspan.firstChild.nodeValue = targetTspan.firstChild.nodeValue; }\r\n   }\r\n   if ( null != SVG_IDX2_tiptspan.firstChild.nodeValue &&  '' != SVG_IDX2_tiptspan.firstChild.nodeValue.trim() )\r\n   {\r\n      var outline = SVG_IDX2_singleText.getBBox();\r\n      SVG_IDX2_singleBox.setAttributeNS(null, 'transform', 'scale(' + SVG_IDX2_attrScale + ',' + SVG_IDX2_attrScale + ')' );\r\n      SVG_IDX2_singleText.setAttributeNS(null, 'transform', 'scale(' + SVG_IDX2_attrScale + ',' + SVG_IDX2_attrScale + ')' );\r\n      SVG_IDX2_singleTip.setAttributeNS(null, 'visibility', 'visible');\r\n      if (evt.clientX + ((outline.width + 10)/1.04) * SVG_IDX2_attrScale > SVG_IDX2_rightEdge) {\r\n         var xPos = SVG_IDX2_TrueCoords.x - parseInt((outline.width + 10)*SVG_IDX2_attrScale);\r\n         if (xPos < 0)\r\n            xPos = 0;\r\n      }\r\n      else\r\n         var xPos = SVG_IDX2_TrueCoords.x;\r\n      if (SVG_IDX2_TrueCoords.y < 20) {\r\n         var yPos = SVG_IDX2_TrueCoords.y + ((outline.height + 20)/1.04)*SVG_IDX2_attrScale;\r\n         if (yPos > windowHeight)\r\n            yPos = SVG_IDX2_TrueCoords.y - parseInt((outline.height + 10)*SVG_IDX2_attrScale);\r\n      }\r\n      else\r\n         var yPos = SVG_IDX2_TrueCoords.y - parseInt((outline.height + 10)*SVG_IDX2_attrScale);\r\n      if (Number(outline.width == 0))\r\n         SVG_IDX2_singleBox.setAttributeNS(null, 'width', outline.width);\r\n      else\r\n         SVG_IDX2_singleBox.setAttributeNS(null, 'width', outline.width + 10);\r\n      SVG_IDX2_singleBox.setAttributeNS(null, 'height', outline.height + 10);\r\n      SVG_IDX2_singleTip.setAttributeNS(null, 'transform', 'translate(' + xPos + ',' + yPos + ')');\r\n   }\r\n}\r\n</script>\r\n<svg xmlns=\"http://www.w3.org/2000/svg\" xmlns:xlink=\"http://www.w3.org/1999/xlink\" xml:space=\"preserve\" baseProfile=\"full\" version=\"1.1\" id=\"SVG_IDX2\" onload='SVG_IDX2_Init(\"SVG_IDX2\")' viewBox=\"-1 -1 625 625\" height=\"624\" width=\"624\">\r\n<desc id=\"desc_SVG_IDX2\">Overview</desc>\r\n<defs>\r\n<clipPath id=\"SVG_IDX2_clipPage1\">\r\n<rect x=\"-1\" y=\"-1\" width=\"625\" height=\"625\"></rect>\r\n</clipPath>\r\n</defs>\r\n<g id=\"SVG_IDX2_Page1\" clip-path=\"url(#SVG_IDX2_clipPage1)\">\r\n<g transform=\" scale(1, 1)\">\r\n<rect x=\"0\" y=\"0\" width=\"623\" height=\"623\" style=\"fill: #FFFFFF; \"></rect>\r\n<rect x=\"0\" y=\"0\" width=\"623\" height=\"623\" style=\"fill: #FFFFFF; \"></rect>\r\n<rect x=\"0\" y=\"0\" width=\"623\" height=\"623\" style=\"stroke: #D1D1D1; stroke-width: 1; fill: none; \"></rect>\r\n<g transform=\"matrix(1, 0, 0, 1, 11, 11)\">\r\n<defs>\r\n<clipPath id=\"SVG_IDX2_ClipPath0\">\r\n<rect x=\"-1\" y=\"-1\" width=\"603\" height=\"24\" ></rect>\r\n</clipPath>\r\n</defs>\r\n<g clip-path=\"url(#SVG_IDX2_ClipPath0)\">\r\n<defs>\r\n<clipPath id=\"SVG_IDX2_ClipPath1\">\r\n<rect x=\"-1\" y=\"-1\" width=\"603\" height=\"24\" ></rect>\r\n</clipPath>\r\n</defs>\r\n<g clip-path=\"url(#SVG_IDX2_ClipPath1)\">\r\n<g transform=\"matrix(1, 0, 0, 1, 202, 0)\">\r\n<defs>\r\n<clipPath id=\"SVG_IDX2_ClipPath2\">\r\n<rect x=\"-1\" y=\"-1\" width=\"200\" height=\"19\" ></rect>\r\n</clipPath>\r\n</defs>\r\n<g clip-path=\"url(#SVG_IDX2_ClipPath2)\">\r\n<text textLength=\"192\" lengthAdjust=\"spacingAndGlyphs\" x=\"3.5\" y=\"13.5791\" style=\"fill: #000000; font-family: 'SVG_IDX2_Albany AMT Font3', 'Albany AMT', sans-serif; font-size: 15px; font-weight: bold; white-space: pre; \">&#x000043;&#x00006C;&#x000061;&#x000073;&#x000073;&#x000069;&#x000066;&#x000069;&#x000063;&#x000061;&#x000074;&#x000069;&#x00006F;&#x00006E;&#x000020;&#x000054;&#x000072;&#x000065;&#x000065;&#x000020;&#x000066;&#x00006F;&#x000072;&#x000020;&#x000042;&#x000041;&#x000044;</text>\r\n</g>\r\n</g>\r\n</g>\r\n</g>\r\n</g>\r\n<g transform=\"matrix(1, 0, 0, 1, 11, 34)\">\r\n<defs>\r\n<clipPath id=\"SVG_IDX2_ClipPath3\">\r\n<rect x=\"-1\" y=\"-1\" width=\"603\" height=\"580\" ></rect>\r\n</clipPath>\r\n</defs>\r\n<g clip-path=\"url(#SVG_IDX2_ClipPath3)\">\r\n<defs>\r\n<clipPath id=\"SVG_IDX2_ClipPath4\">\r\n<rect x=\"-1\" y=\"-1\" width=\"603\" height=\"552\" ></rect>\r\n</clipPath>\r\n</defs>\r\n<g clip-path=\"url(#SVG_IDX2_ClipPath4)\">\r\n<g transform=\"matrix(0.04937, 0, 0, 0.04937, 359.57937, 25.29659)\">\r\n<path d=\"M38.030