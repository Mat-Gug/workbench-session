 unicode=\"&#84;\" horiz-adv-x=\"1190\" \r\nd=\"M1152 1280L682 1280L682 0L512 0L512 1280L42 1280L42 1450L1152 1450L1152 \r\n1280Z\" ></glyph>\r\n<glyph unicode=\"&#85;\" horiz-adv-x=\"1487\" \r\nd=\"M1322 552Q1322 301 1171 150 T746 0Q474 0 322 149 T170 548L170 1450L341 \r\n1450L341 564Q341 380 447 275 T740 170Q930 170 1041 277 T1152 568L1152 1450L\r\n1322 1450L1322 552Z\" ></glyph>\r\n<glyph unicode=\"&#86;\" horiz-adv-x=\"1360\" \r\nd=\"M1333 1450L749 0L573 0L-10 1450L169 1450L661 228L1153 1450L1333 1450Z\" ></glyph>\r\n<glyph unicode=\"&#87;\" horiz-adv-x=\"2040\" \r\nd=\"M2016 1450L1612 0L1428 0L1045 1217L663 0L487 0L32 1450L208 1450L576 \r\n279L944 1450L1146 1450L1514 279L1840 1450L2016 1450Z\" ></glyph>\r\n<glyph unicode=\"&#88;\" horiz-adv-x=\"1317\" \r\nd=\"M1290 0L1095 0L661 643L228 0L32 0L563 788L117 1450L312 1450L661 \r\n933L1009 1450L1205 1450L759 788L1290 0Z\" ></glyph>\r\n<glyph unicode=\"&#89;\" horiz-adv-x=\"1275\" \r\nd=\"M1290 1450L725 578L725 0L554 0L554 578L-10 1450L184 1450L640 747L1096 \r\n1450L1290 1450Z\" ></glyph>\r\n<glyph unicode=\"&#90;\" horiz-adv-x=\"1232\" \r\nd=\"M1194 0L85 0L85 143L932 1280L128 1280L128 1450L1152 1450L1152 1302L308 \r\n170L1194 170L1194 0Z\" ></glyph>\r\n<glyph unicode=\"&#97;\" horiz-adv-x=\"1147\" \r\nd=\"M1077 0L906 0Q884 22 869 62 T853 128Q660 0 429 0 Q276 0 180 74 T\r\n85 282Q85 387 142 460 T314 573T606 625L853 640L853 668Q853 796 790 \r\n846 T569 896Q493 896 381 870 T192 810L128 981Q218 1019 348 1043 T587 1066Q\r\n810 1066 917 972 T1024 686L1024 248Q1024 84 1077 0ZM853 298L853 512Q616 \r\n500 542 493 T398 464T292 402T256 304Q256 244 310 207 T449 170Q557 170 \r\n671 206 T853 298Z\" ></glyph>\r\n<glyph unicode=\"&#98;\" horiz-adv-x=\"1147\" \r\nd=\"M298 938Q430 1066 626 1066 Q814 1066 940 924 T1066 554Q1066 299 940 149 T620 \r\n0Q423 0 298 128 L298 0L128 0L128 1493L298 1493L298 938ZM298 768L298 \r\n298Q341 245 421 208 T586 170Q730 170 813 267 T896 538Q896 709 814 802 T\r\n586 896Q511 896 433 860 T298 768Z\" ></gly