mns</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<th class=\"rowheader\" scope=\"row\">casuser</th>\n<th class=\"rowheader\" scope=\"row\">TREESTORE_HMEQ</th>\n<td class=\"r data\">1</td>\n<td class=\"r data\">2</td>\n</tr>\n</tbody>\n</table>\n</div>\n</div>\n</div>\n</body>\n</html>\n","mime":"application/vnd.sas.ods.html5"},{"data":"[\n\t{\n\t\t\"line\": \"284  /** LOG_START_INDICATOR **/\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"285  title;footnote;ods _all_ close;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"286  ods graphics on;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"287  ods html5(id=vscode) style=HTMLEncore options(bitmap_mode='inline' svg_mode='inline');\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"NOTE: Writing HTML5(VSCODE) Body file: sashtml14.htm\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"288  %let _SASPROGRAMFILE = %nrquote(%nrstr(/workspaces/myfolder/workbench-session/Model registration - SAS.sasnb));\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"289  libname mylib '/workspaces/myfolder/workbench-session/data';\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"NOTE: Libref MYLIB was successfully assigned as follows: \",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"      Engine:        V9 \",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"      Physical Name: /workspaces/myfolder/workbench-session/data\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"290  \",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"291  proc treesplit data = mylib.hmeq;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"292     input loan value mortdue debtinc derog / level = interval;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"293     input job / level = nominal;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"294     target bad / level = nominal;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"295     prune none;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"296     saveState rstore = mylib.treeStore_hmeq;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"297  run;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"NOTE: 14021 bytes were written to the table \\\"TREESTORE_HMEQ\\\".\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"NOTE: SAS Viya processed the request in 0.051357 seconds.\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"NOTE: Standard Deviations of Variable Importance are missing because the model has only one tree (or iteration).\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"NOTE: SAS Viya processed the request in 0.010392 seconds.\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"NOTE: SAS Viya processed the request in 0.001122 seconds.\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"NOTE: SAS Viya processed the request in 0.000394 seconds.\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"11                                                         The SAS System                       Friday, October  4, 2024 01:06:00 PM\",\n\t\t\"type\": \"title\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"\",\n\t\t\"type\": \"title\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"NOTE: The output analytic store MYLIB.TREESTORE_HMEQ is simply a reference to the analytic store TREESTORE_HMEQ that is in memory. \",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"      To save the in-memory store on disk, use the DOWNLOAD statement in the ASTORE procedure.\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"NOTE: The data set MYLIB.TREESTORE_HMEQ has 1 observations and 2 variables.\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"NOTE: PROCEDURE TREESPLIT used (Total process time):\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"      real time           1.16 seconds\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"      cpu time            0.34 seconds\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"      \",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"298  ;*';*\\\";*/;run;quit;ods html5(id=vscode) close;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t}\n]","mime":"application/vnd.sas.compute.log.lines"}]}]},{"kind":1,"language":"markdown","value":"The PROC ASTORE Statement has been used to retrieve the external binary analytic store produced by the TREESPLIT procedure and stores it in the local file system. To do that, the following 2 options must be specified in the DOWNLOAD statement:\n- RSTORE. It specifies the data table that contains the state to be downloaded.\n- STORE. It specifies either the file reference or the full path of the local analytic store file to which the contents of the data table are to be downloaded.","outputs":[]},{"kind":2,"language":"sas","value":"proc astore;\n   download rstore = mylib.treeStore_hmeq\n            store = \"/workspaces/myfolder/workbench-session/treeAstore.sasast\";\nrun;","outputs":[{"items":[{"data":"[\n\t{\n\t\t\"line\": \"299  /** LOG_START_INDICATOR **/\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"300  title;footnote;ods _all_ close;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"301  ods graphics on;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"302  ods html5(id=vscode) style=HTMLEncore options(bitmap_mode='inline' svg_mode='inline');\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"NOTE: Writing HTML5(VSCODE) Body file: sashtml15.htm\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"303  %let _SASPROGRAMFILE = %nrquote(%nrstr(/workspaces/myfolder/workbench-session/Model registration - SAS.sasnb));\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"304  proc astore;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"305     download rstore = mylib.treeStore_hmeq\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"306              store = \\\"/workspaces/myfolder/workbench-session/treeAstore.sasast\\\";\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"NOTE: 14021 bytes were downloaded from the table \\\"TREESTORE_HMEQ\\\".\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"NOTE: The analytic store file was saved in \\\"/workspaces/myfolder/workbench-session/treeAstore.sasast\\\".\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"307  run;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"NOTE: PROCEDURE ASTORE used (Total process time):\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"      real time           0.05 seconds\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"      cpu time            0.02 seconds\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"      \",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"\",\n\t\t\"type\": \"note\",\n\t\t\"version\": 1\n\t},\n\t{\n\t\t\"line\": \"308  ;*';*\\\";*/;run;quit;ods html5(id=vscode) close;\",\n\t\t\"type\": \"source\",\n\t\t\"version\": 1\n\t}\n]","mime":"application/vnd.sas.compute.log.lines"}]}]},{"kind":1,"language":"markdown","value":"Our goal is to register this analytic store model in SAS Model Manager. To this aim, we need to retrieve an authentication token from the SAS Viya deployment where SAS Model Manager is located. To obtain it, run the following code in Python in SAS Studio on the Viya server you want to import your model to:\n```python\nimport os\nprint(os.environ['SAS_SERVICES_TOKEN'])\n```\nThis will print out a giant string of characters that is your OAuth token. Copy and paste that in the following macro code:","outputs":[]},{"kind":2,"language":"sas","value":"/* get token */\n/*\n%macro myTokenName() / secure;\n\"Bearer <access-token-string>\"\n%mend;\n*/\n%macro myTokenName() / secure;\n\"Bearer eyJqa3UiOiJodHRwczovL2xvY2FsaG9zdC9TQVNMb2dvbi90b2tlbl9rZXlzIiwia2lkIjoibGVnYWN5LXRva2VuLWtleSIsInR5cCI6IkpXVCIsImFsZyI6IlJTMjU2In0.\neyJzdWIiOiJkMTE0ODRiZC0xYTE0LTQyY2ItOGU3OS1mZjNiOGIxMDM4MzQiLCJ1c2VyX25hbWUiOiJNYXR0aWEuR3VnbGllbG1lbGxpQHNhcy5jb20iLCJvcmlnaW4iOiJh\nenVyZSIsImlzcyI6Imh0dHA6Ly9sb2NhbGhvc3QvU0FTTG9nb24vb2F1dGgvdG9rZW4iLCJhdXRob3JpdGllcyI6WyJTQVNTY29yZVVzZXJzIiwiRGF0YUJ1aWxkZXJzIiwi\nR2xvc3NhcnkuR2xvc3NhcnlBZG1pbmlzdHJhdG9ycyIsIkNJUyBWaXlhIEFsd2F5cyBPbiIsIkNhdGFsb2cuU3ViamVjdE1hdHRlckV4cGVydHMiLCJBcHBsaWNhdGlvbkFk\nbWluaXN0cmF0b3JzIiwiSUNVcyIsIk1pZ3JhdGlvbkFkbWlucyIsIkVzcmlVc2VycyIsIkNBU0hvc3RBY2NvdW50UmVxdWlyZWQiXSwiY2xpZW50X2lkIjoic2FzLmxhdW5j\naGVyIiwiYXVkIjpbInNhcy5sYXVuY2hlciIsInVhYSJdLCJleHRfaWQiOiI5Vjd0QTJpY01ubzc0WTQ4a1lNZDdRenJIbFRTaHdxeHF3eWpPLUtGdFpzIiwiemlkIjoidWFh\nIiwiZ3JhbnRfdHlwZSI6InVybjppZXRmOnBhcmFtczpvYXV0aDpncmFudC10eXBlOmp3dC1iZWFyZXIiLCJ1c2VyX2lkIjoiZDExNDg0YmQtMWExNC00MmNiLThlNzktZmYz\nYjhiMTAzODM0IiwiYXpwIjoic2FzLmxhdW5jaGVyIiwic2NvcGUiOlsidWFhLnVzZXIiXSwiZXhwIjoxNzI4MDMzNzU1LCJpYXQiOjE3MjgwMzAxNTUsImp0aSI6I